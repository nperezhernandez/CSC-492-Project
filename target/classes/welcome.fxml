<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" alignment="CENTER"
    style="-fx-background-color: #F5F5DC;"
    xmlns:fx="http://javafx.com/fxml"
    fx:controller="controllers.WelcomeController">

    <Label text="Welcome to the CSUDH Enrollment Prediction System"
        style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <Button text="Enrollment Dashboard"
         onAction="#openDashboard"
         prefWidth="250"/>

    <Button text="Capacity Planner"
        onAction="#openCapacityPlanner"
        prefWidth="250"/>
        
    <Button text="Course Information"
        onAction="#openCourseInformation"
        prefWidth="250"/>

    <Button text="Exit"
        onAction="#exitApplication"
        prefWidth="250"/>

</VBox>